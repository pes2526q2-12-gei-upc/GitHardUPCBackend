#!/bin/bash

echo "🔍 Ejecutando análisis estático y tests unitarios (Backend)..."

# Solo ejecutamos Maven si existe el archivo mvnw
if [ -f "./mvnw" ]; then
    # Ejecutamos tests y Checkstyle (si lo tienes configurado) para cumplir con el RNF de sintaxis [cite: 632, 678]
    mvn clean test

    if [ $? -ne 0 ]; then
        echo "🛑 Error: Las pruebas han fallado. Revisa tu lógica antes de hacer commit." [cite: 633]
        exit 1
    fi
else
    echo "⚠️  Atención: No se encontró ./mvnw. ¿Estás en la raíz del proyecto Backend?"
    exit 1
fi

echo "✅ Validación completada. Procediendo con el commit..."
exit 0